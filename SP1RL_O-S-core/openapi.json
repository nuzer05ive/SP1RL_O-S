    "/pedal/signoff": {"post": {"summary": "6 strokes → sign-off", "security": [{"token": []}]}},
    "/opposite/next": {"get": {"summary": "get pair", "security": [{"token": []}]}},
    "/opposite/vote": {"post": {"summary": "yes/no vote (+strokes)", "security": [{"token": []}]}},
    "/ivy/mint": {"post": {"summary": "mint petal object", "security": [{"token": []}]}},
    "/git/approve_pr": {"post": {"summary": "Serpent merge", "security": [{"serpent": []}]}}
